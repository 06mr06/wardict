# Firebase Configuration - EXAMPLE FILE
# This is a template file. DO NOT commit your actual .env file to version control.
# Copy this file to .env and replace the values with your actual Firebase credentials.
# 
# Your .env file will be loaded at runtime and should NEVER be committed to git.

# Firebase API Key (Web)
FIREBASE_API_KEY=your_firebase_api_key_here

# Firebase App ID (Web)
FIREBASE_APP_ID=your_firebase_app_id_here

# Firebase Auth Domain
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com

# Firebase Project ID
FIREBASE_PROJECT_ID=your_project_id

# Firebase Storage Bucket
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app

# Firebase Messaging Sender ID
FIREBASE_MESSAGING_SENDER_ID=your_sender_id

# Firebase Measurement ID (Analytics)
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase Realtime Database URL (ZORUNLU — online düello için bölge URL'i)
# US-central değilse: https://<project>-default-rtdb.<region>.firebasedatabase.app/
FIREBASE_DATABASE_URL=https://YOUR_PROJECT_ID-default-rtdb.firebaseio.com/

# AdMob Configuration
ADMOB_BANNER_ID=your_admob_banner_id
ADMOB_INTERSTITIAL_ID=your_admob_interstitial_id
ADMOB_REWARDED_ID=your_admob_rewarded_id
# Release'de gerçek reklam göstermek için true yap (yoksa otomatik test ID).
ADMOB_FORCE_PRODUCTION=false
# 13 yaş altına yönelik (COPPA). Default false: yetişkin hedeflemeyi açık bırakır.
ADMOB_CHILD_DIRECTED=false

# Firebase App Check — Debug token (Firebase Console → App Check → Debug'dan al)
APP_CHECK_DEBUG_TOKEN=

# Android/iOS use google-services.json and GoogleService-Info.plist respectively
# which should be obtained from Firebase Console and kept in .gitignore
