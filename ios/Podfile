# Tamamen temizlenmiş ve Codemagic'i hataya zorlayan eski satırlardan arındırılmış Podfile

platform :ios, '13.0'

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # Doğrudan Flutter'ın kendi ürettiği güncel bof dosyasına bakıyoruz
  generated_pods_definition_path = File.expand_path(File.join('..', 'Flutter', 'generated_pods.rb'), __dir__)
  
  if File.exist?(generated_pods_definition_path)
    require generated_pods_definition_path
    flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  else
    raise "generated_pods.rb bulunamadı. Lütfen yerelde 'flutter pub get' çalıştırın."
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end
end