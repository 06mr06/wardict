platform :ios, '13.0'

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # Sadece yeni nesil Flutter entegrasyon dosyasını çağırıyoruz.
  # Eğer o da bulutta henüz oluşmadıysa CocoaPods hata fırlatmasın diye korumaya aldık.
  generated_pods_definition_path = File.expand_path(File.join('..', 'Flutter', 'generated_pods.rb'), __dir__)
  if File.file?(generated_pods_definition_path)
    require generated_pods_definition_path
    flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end
end