# Eski .flutter-plugins-dependencies dosyasını arayan satırları tamamen kaldırdık.
# Güncel Flutter yapısı doğrudan generated_pods.rb dosyasına bakar.

plugin_pods_path = File.expand_path(File.join('..', '.flutter-plugins-dependencies'), __dir__)
if File.exist?(plugin_pods_path)
  require plugin_pods_path
end

# Flutter'ın asıl ihtiyaç duyduğu güncel entegrasyon dosyası:
generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __dir__)
unless File.exist?(generated_xcode_build_settings_path)
  raise "Generated.xcconfig not found. Run 'flutter pub get' and build the project first."
end

platform :ios, '13.0'

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # Eğer generated_pods.rb mevcutsa yükle (Flutter 3.x+ standartı)
  generated_pods_definition_path = File.expand_path(File.join('..', 'Flutter', 'generated_pods.rb'), __dir__)
  if File.exist?(generated_pods_definition_path)
    require generated_pods_definition_path
    flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end
end