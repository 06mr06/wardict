# Satır sonu karakterleri veya eski Flutter script yönlendirmelerini düzelten kısım burası
flutter_ios_podfile_setup_path = File.expand_path(File.join('..', '.flutter-plugins-dependencies'), __dir__)
require flutter_ios_podfile_setup_path if File.exist?(flutter_ios_podfile_setup_path)

platform :ios, '14.0' # Eğer projen daha yüksek bir iOS sürümü istiyorsa (örn: 14.0) burayı değiştirebilirsin

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  
  # NOT: Eğer projenizde Firebase veya başka bir paket için manuel eklediğin 
  # 'pod 'Firebase/Analytics'' gibi özel satırlar varsa, onları TAM BURAYA ekleyebilirsin.
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end
end